{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=smessenger_auth;Username=postgres;Password=postgres"
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Secret": "your-super-secret-key-min-32-chars",
    "Issuer": "smessenger-auth",
    "Audience": "smessenger",
    "AccessTokenExpireMin": 15,
    "RefreshTokenExpireDays": 30
  }
}
